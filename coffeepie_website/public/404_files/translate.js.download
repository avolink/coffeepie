let translationsData = null;

async function loadTranslations() {
    if (!translationsData) {
        try {
            // Adjust path if needed, assuming translations.json is at root of public
            const response = await fetch('/translations.json');
            const data = await response.json();
            // Normalize keys by trimming and replacing multiple spaces/newlines with a single space
            translationsData = {};
            for (const key in data) {
                const normalizedKey = key.trim().replace(/\s+/g, ' ');
                translationsData[normalizedKey] = data[key];
            }
        } catch (e) {
            console.error('Failed to load translations:', e);
        }
    }
    return translationsData;
}

async function setLanguage(lang) {
    const data = await loadTranslations();
    if (!data) return;

    // Save preference
    localStorage.setItem('coffee_pie_lang', lang);

    // Update text nodes
    const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null, false);
    const nodes = [];
    while (walker.nextNode()) nodes.push(walker.currentNode);

    nodes.forEach(node => {
        if (!node.parentElement) return;
        const tag = node.parentElement.tagName;
        if (tag === 'SCRIPT' || tag === 'STYLE' || tag === 'NOSCRIPT') return;

        // Skip translation for elements inside the table or marked with data-no-translate
        if (node.parentElement.closest('#comp-mhgg3kom') || node.parentElement.closest('[data-no-translate="true"]')) {
            return;
        }

        // Remember the original text of the node (which is Spanish upon page load)
        if (typeof node._originalValue === 'undefined') {
            node._originalValue = node.nodeValue;
        }

        const text = (node._originalValue || '').trim().replace(/\s+/g, ' ');
        // Protect language switch buttons from being translated
        if (text === 'EN' || text === 'ES' || text === 'IN' || text === 'IS') return;

        // Use the normalized text as the key to look up the translation
        if (text && data[text] && data[text][lang]) {
            // Replace the key within the original text preserving the original spacing
            // Actually, we can just use the translation since Wix usually wraps text nodes tightly
            node.nodeValue = node._originalValue.replace(node._originalValue.trim(), data[text][lang]);
        }
    });

    // Update active state of language buttons
    document.querySelectorAll('.wixui-language-menu__option').forEach(btn => {
        const labelEl = btn.querySelector('.J6PIw1') || btn.querySelector('div:last-child');
        if (labelEl) {
            const btnLang = labelEl.textContent.trim().toLowerCase();
            if (btnLang === lang) {
                btn.setAttribute('aria-current', 'true');
                btn.classList.add('wbgQXa'); // Wix active class
            } else {
                btn.setAttribute('aria-current', 'false');
                btn.classList.remove('wbgQXa');
            }
        }
    });
}

function initTranslation() {
    // Attach click listeners to language switch options
    const langButtons = document.querySelectorAll('.wixui-language-menu__option');
    langButtons.forEach(btn => {
        // Prevent default Wix routing if any
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            const labelEl = btn.querySelector('.J6PIw1') || btn.querySelector('div:last-child');
            if (labelEl) {
                const lang = labelEl.textContent.trim().toLowerCase(); // 'es' or 'en'
                setLanguage(lang);
            }
        });
    });

    // Apply saved language if any
    const savedLang = localStorage.getItem('coffee_pie_lang');
    if (savedLang) {
        setLanguage(savedLang);
    }
}

// Initialize on load
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTranslation);
} else {
    initTranslation();
}
