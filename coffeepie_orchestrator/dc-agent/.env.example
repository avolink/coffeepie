# Coffee Pie DC Agent — Environment Configuration
# Copy this to .env and fill in your values before starting the agent.

# Bind address for the DC Agent HTTP server
DC_AGENT_BIND=0.0.0.0:9090

# Hypervisor type (currently supported: proxmox)
DC_AGENT_HYPERVISOR=proxmox

# Base URL of the hypervisor management API (proxmox_backend FastAPI)
DC_AGENT_BACKEND_URL=https://proxmox-api.dc1.lan

# Firebase ID token for authenticating to the proxmox_backend
DC_AGENT_BEARER_TOKEN=your-firebase-id-token-here

# Unique identifier for this DC Agent instance
# Auto-generated if not set (dc-agent-<uuid>)
DC_AGENT_ID=dc-agent-us-east-1

# Central QFDM broker URL for heartbeat reporting
# Omit to disable heartbeat (standalone mode)
QFDM_BROKER_URL=https://broker.coffeepie.co
