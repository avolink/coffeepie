# Coffee Pie DC Agent — Environment Configuration
# Copy this to .env and fill in your values before starting the agent.

# Bind address for the DC Agent HTTP server
DC_AGENT_BIND=0.0.0.0:9090

# Hypervisor type (currently supported: proxmox)
DC_AGENT_HYPERVISOR=proxmox

# Base URL of the hypervisor management API (proxmox_backend FastAPI)
DC_AGENT_BACKEND_URL=https://proxmox-api.dc1.lan

# ── Authentication ──────────────────────────────────────────────────────
#
# DC_AGENT_BEARER_TOKEN: Firebase token for authenticating to the proxmox_backend.
#   IMPORTANT: Firebase ID tokens expire after 1 hour. For production, use a
#   Firebase custom token (created via auth_service.create_custom_token) which
#   can be long-lived. The DC Agent does NOT auto-refresh tokens — a cron job
#   or external process must rotate this token periodically.
#   If the token expires, the proxmox_backend returns HTTP 401 and the DC Agent
#   will report errors. A future update will add automatic token refresh.
DC_AGENT_BEARER_TOKEN=your-firebase-token-here

# DC_AGENT_AUTH_TOKEN: Shared secret for authenticating requests from the central
#   QFDM broker to this DC Agent's mutation endpoints (/instances, /start, /stop,
#   /destroy). The broker must send `Authorization: Bearer <this-token>`.
#   If empty or unset, mutation endpoints are UNAUTHENTICATED (development only).
#   Generate with: openssl rand -base64 32
DC_AGENT_AUTH_TOKEN=

# ── Identification ──────────────────────────────────────────────────────

# Unique identifier for this DC Agent instance
# Auto-generated if not set (dc-agent-<uuid>)
DC_AGENT_ID=dc-agent-us-east-1

# ── Broker ──────────────────────────────────────────────────────────────

# Central QFDM broker URL for heartbeat reporting
# Omit to disable heartbeat (standalone mode)
QFDM_BROKER_URL=https://broker.coffeepie.co

# ── CORS (optional) ─────────────────────────────────────────────────────
#
# DC_AGENT_CORS_ORIGIN: If your monitoring dashboard needs browser access to
#   the DC Agent's read-only endpoints (/health, /capacity, /templates), set
#   this to the dashboard's origin (e.g., https://dashboard.coffeepie.co).
#   Leave empty for server-to-server operation (no CORS headers).
#   Mutation endpoints always require DC_AGENT_AUTH_TOKEN regardless of CORS.
DC_AGENT_CORS_ORIGIN=
