	path = actor
	url = https://github.com/VirtualCable/uds-actor.git
	branch = master
[submodule "client-py3"]
	path = client
	url = https://github.com/VirtualCable/uds-client.git
	branch = master
[submodule "server"]
	path = server
	url = https://github.com/VirtualCable/uds-broker.git
	branch = master
