# Coffee Pie — Environment Configuration
# Copy to .env and customize for your development setup.
# cp .env.example .env

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_DB=coffeepie
POSTGRES_USER=coffeepie
POSTGRES_PASSWORD=coffeepie_dev

# ── Orchestrator (Django) ──────────────────────────────────
ORCH_SECRET_KEY=dev-secret-key-change-in-production-do-not-use-this-value
ORCH_DEBUG=true

# ── DC Agent ───────────────────────────────────────────────
DC_AGENT_HYPERVISOR=proxmox-mock
DC_AGENT_AUTH_TOKEN=dev-agent-token
DC_AGENT_LOG=debug

# ── Actor ──────────────────────────────────────────────────
ACTOR_LOG=debug

# ── Supabase (optional, for IAM) ───────────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=eyJhbGci...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Firebase (legacy, being migrated to Supabase) ──────────
# FIREBASE_PROJECT_ID=coffeepie-dev
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@coffeepie-dev.iam.gserviceaccount.com
