# Proxmox connection
PROXMOX_URL=https://your-proxmox-host:8006/api2/json
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=your-proxmox-password

# Firebase (from Firebase Console -> Project Settings -> General -> Web app)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin SDK (path to service account JSON)
FIREBASE_ADMIN_SDK_JSON=app/secrets/firebase-adminsdk.json

# Sunshine credentials
SUNSHINE_USERNAME=coffeepie
SUNSHINE_PASSWORD=coffeepie
