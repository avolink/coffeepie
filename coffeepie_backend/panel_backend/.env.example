# Panel backend identity selection
# AUTH_PROVIDER: supabase | firebase | both  (default: both, for the migration window)
AUTH_PROVIDER=both

# ── Supabase (production IAM — self-hostable, sovereign) ──
SUPABASE_URL=https://your-project.supabase.co
# Leave SUPABASE_JWT_SECRET unset to verify via JWKS (asymmetric, current default).
# Set it only for legacy HS256 projects.
# SUPABASE_JWT_SECRET=your-jwt-secret

# ── Firebase (prototype/legacy) ──
# FIREBASE_PROJECT_ID=coffeepie-dev
# FIREBASE_ADMIN_SDK_JSON=app/secrets/firebase-adminsdk.json
