# Panel backend identity selection
# AUTH_PROVIDER: supabase | firebase | both  (default: both, for the migration window)
AUTH_PROVIDER=both

# ── Supabase (production IAM — self-hostable, sovereign) ──
SUPABASE_URL=https://your-project.supabase.co
# Leave SUPABASE_JWT_SECRET unset to verify via JWKS (asymmetric, current default).
# Set it only for legacy HS256 projects.
# SUPABASE_JWT_SECRET=your-jwt-secret

# Direct Postgres connection to the Supabase project (Project Settings →
# Database → Connection string). Used by app/db.py for everything the panel
# reads/writes (nodes, ledger, campaigns, etc.) — separate from Supabase Auth
# above, which only verifies the caller's JWT.
# DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Fernet key encrypting node.root_password_enc (app/auth/node_credentials.py).
# MUST be a real secret here, never the QA-only default baked into that file.
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NODE_CRED_ENC_KEY=

# ── Firebase (prototype/legacy) ──
# FIREBASE_PROJECT_ID=coffeepie-dev
# FIREBASE_ADMIN_SDK_JSON=app/secrets/firebase-adminsdk.json
